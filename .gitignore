# ── secrets: NEVER commit ──
secrets.env
.env
*.key
*.pem
*.crt
# requirements PDF embeds a provider API key (§7.1, 严禁外泄) — keep out of git
*.pdf

# ── submission drafts (local working copy, not part of the repo) ──
submission/

# ── design docs / notes: local only, repo ships README + code ──
docs/
prompt.md
zijiedesign.md
experiments/
*.bak.note

# ── runtime data / DB / logs / scratch ──
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
logs/
*.log
tmp/
.cache/

# ── archived / generated UI ──
web/archive/

# ── the delivery test-target (its own git repo, large) ──
experiments/conduit/

# ── python ──
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── node ──
node_modules/
npm-debug.log*

# ── agent / tooling state (local only) ──
.claude/
.agents/
.codex/

# ── editor / OS ──
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
